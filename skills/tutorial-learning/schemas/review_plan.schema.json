{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review_plan.schema.json",
  "title": "ReviewPlan",
  "type": "object",
  "required": ["section_id", "cards", "schedule"],
  "properties": {
    "section_id": { "type": "string" },
    "cards": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "prompt", "answer_hint", "mastery", "objective_ids", "source_trace_ids"],
        "properties": {
          "id": { "type": "string" },
          "prompt": { "type": "string" },
          "answer_hint": { "type": "string" },
          "mastery": { "enum": ["exposure", "recall", "application"] },
          "objective_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "source_trace_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "schedule": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["card_id", "due_offsets_days"],
        "properties": {
          "card_id": { "type": "string" },
          "due_offsets_days": { "type": "array", "minItems": 1, "items": { "type": "integer", "minimum": 1 } }
        }
      }
    }
  }
}
