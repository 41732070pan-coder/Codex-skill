{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "next_lesson_context.schema.json",
  "title": "NextLessonContext",
  "type": "object",
  "required": ["version", "course_id", "generated_at", "trigger", "next_lesson_id", "source_state_file", "explanation_preference", "completed_lesson_ids", "learning_signals"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "course_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "trigger": { "enum": ["initial", "next_lesson_generation", "manual_resume"] },
    "next_lesson_id": { "type": "string" },
    "source_state_file": { "type": "string" },
    "explanation_preference": { "enum": ["balanced", "intuition-first", "math-focused", "practice-focused"] },
    "completed_lesson_ids": { "type": "array", "items": { "type": "string" } },
    "learning_signals": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": false
}
