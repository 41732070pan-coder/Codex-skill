{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "learner_state.schema.json",
  "title": "LearnerState",
  "type": "object",
  "required": ["version", "course_id", "updated_at", "preferences", "lesson_records", "review_records", "notes"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "course_id": { "type": "string" },
    "updated_at": { "type": "string" },
    "preferences": {
      "type": "object",
      "required": ["explanation_preference"],
      "properties": { "explanation_preference": { "enum": ["balanced", "intuition-first", "math-focused", "practice-focused"] } },
      "additionalProperties": false
    },
    "lesson_records": { "type": "array", "items": { "type": "object" } },
    "review_records": { "type": "array", "items": { "type": "object" } },
    "notes": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": false
}
