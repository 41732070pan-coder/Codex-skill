{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evaluator_report.schema.json",
  "title": "EvaluatorReport",
  "type": "object",
  "required": [
    "scores",
    "blocking_failures",
    "patches",
    "delivery_allowed"
  ],
  "properties": {
    "scores": {
      "type": "object",
      "required": [
        "source_fidelity",
        "source_evidence_depth",
        "triage_depth_routing",
        "chinese_lecture_quality",
        "lesson_learning_value",
        "assessment_diagnostics",
        "personalization",
        "tutorial_design_completeness"
      ],
      "additionalProperties": false,
      "properties": {
        "source_fidelity": {
          "$ref": "#/$defs/score"
        },
        "source_evidence_depth": {
          "$ref": "#/$defs/score"
        },
        "triage_depth_routing": {
          "$ref": "#/$defs/score"
        },
        "chinese_lecture_quality": {
          "$ref": "#/$defs/score"
        },
        "lesson_learning_value": {
          "$ref": "#/$defs/score"
        },
        "assessment_diagnostics": {
          "$ref": "#/$defs/score"
        },
        "personalization": {
          "$ref": "#/$defs/score"
        },
        "tutorial_design_completeness": {
          "$ref": "#/$defs/score"
        }
      }
    },
    "blocking_failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "priority",
          "issue",
          "fix"
        ],
        "properties": {
          "priority": {
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "issue": {
            "type": "string"
          },
          "fix": {
            "type": "string"
          }
        }
      }
    },
    "delivery_allowed": {
      "type": "boolean"
    }
  },
  "$defs": {
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    }
  }
}
